// prisma/schema.prisma

generator client {
  provider = "prisma-client" // Correct for Prisma 6 Rust-based client
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Note: In Prisma 6, the URL is omitted here. It will be read from your .env file.
}

// ==========================================
// MEDIA & ASSETS
// ==========================================
// Renamed from 'imageCloudinary'. Using a generic name (MediaAsset) is a 
// production best practice. If you ever switch from Cloudinary to AWS S3, 
// you won't have to change your database schema!
model MediaAsset {
  id         Int      @id @default(autoincrement())
  url        String
  publicId   String   @unique // Renamed from public_id to follow camelCase convention
  
  // 1. Relation to Product (One-to-Many: A product can have multiple images)
  productId  Int?
  product    Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  // 2. Reverse side of the 1:1 relation with Category (for the category icon)
  categoryIcon Category? @relation("CategoryIcon")

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([productId]) // Speeds up querying images for a specific product
}

// ==========================================
// CATALOG
// ==========================================
model Category {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  slug        String       @unique // Added for SEO-friendly URLs (e.g., /categories/electronics)
  description String?
  
  // One-to-One relation with MediaAsset for the category icon/image
  iconId      Int?         @unique
  icon        MediaAsset?  @relation("CategoryIcon", fields: [iconId], references: [id], onDelete: SetNull)

  products    Product[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Product {
  id          Int          @id @default(autoincrement())
  name        String
  slug        String       @unique // Added for SEO-friendly URLs (e.g., /products/gaming-laptop)
  description String?
  
  // One-to-Many relation with MediaAsset (pulls all images for this product)
  images      MediaAsset[]
  
  price       Decimal      @db.Decimal(10, 2)
  stock       Int          @default(0)
  isActive    Boolean      @default(true) // Added for "soft disabling" products without deleting them
  
  categoryId  Int
  // Changed to Restrict: Prevents accidental deletion of a Category if it still has products!
  category    Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict) 
  
  orderItems  OrderItem[]
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([categoryId])
  @@index([slug])
  @@index([isActive]) // Speeds up filtering only active products
}

// ==========================================
// ORDERS
// ==========================================
model Order {
  id            Int         @id @default(autoincrement())
  orderNumber   String      @unique // Added for user-friendly order tracking (e.g., ORD-12345)
  
  // Placeholders until we implement Auth/Users
  customerName  String      
  customerEmail String      
  
  totalAmount   Decimal     @db.Decimal(10, 2)
  status        OrderStatus @default(PENDING)
  
  items         OrderItem[]
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([status])
  @@index([customerEmail])
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  
  // --- CRITICAL PRODUCTION FEATURE: SNAPSHOT DATA ---
  // We save the name and price AT THE TIME of purchase.
  // This ensures historical orders don't change if you update the product name/price later.
  productName String 
  unitPrice   Decimal @db.Decimal(10, 2) 
  
  quantity    Int
  
  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}