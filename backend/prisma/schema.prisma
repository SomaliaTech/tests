generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  
}

datasource db {
  provider = "postgresql"
}

model MediaAsset {
  id         String      @id @default(uuid())
  url        String
  publicId   String      @unique
  productId  String?
  product    Product?    @relation(fields: [productId], references: [id], onDelete: Cascade)
  categoryIcon Category? @relation("CategoryIcon")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([productId])
}

model Category {
  id          String      @id @default(uuid())
  name        String      @unique
  slug        String      @unique
  description String?
  iconId      String?     @unique
  icon        MediaAsset? @relation("CategoryIcon", fields: [iconId], references: [id], onDelete: SetNull)
  products    Product[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Product {
  id          String      @id @default(uuid())
  name        String
  description String?
  images      MediaAsset[]
  price       Decimal     @db.Decimal(10, 2)
  stock       Int         @default(0)
  isActive    Boolean     @default(true)
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  variants    ProductVariant[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([categoryId])
  @@index([isActive])
}

model Color {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique
  variants  ProductVariant[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Size {
  id        String   @id @default(uuid())
  name      String   @unique
  value     String   @unique
  variants  ProductVariant[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductVariant {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  colorId   String
  color     Color    @relation(fields: [colorId], references: [id], onDelete: Restrict)
  sizeId    String
  size      Size     @relation(fields: [sizeId], references: [id], onDelete: Restrict)
  sku       String   @unique
  stock     Int      @default(0)
  price     Decimal? @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orderItems OrderItem[]

  @@unique([productId, colorId, sizeId])
  @@index([productId])
  @@index([colorId])
  @@index([sizeId])
  @@index([sku])
}

model Order {
  id            String      @id @default(uuid())
  orderNumber   String      @unique
  customerName  String
  customerEmail String
  totalAmount   Decimal     @db.Decimal(10, 2)
  status        OrderStatus @default(PENDING)
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([status])
  @@index([customerEmail])
}

model OrderItem {
  id               String         @id @default(uuid())
  orderId          String
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)
  productName      String
  variantSku       String
  colorName        String
  sizeName         String
  unitPrice        Decimal        @db.Decimal(10, 2)
  quantity         Int
  createdAt        DateTime       @default(now())

  @@index([orderId])
  @@index([productVariantId])
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}